# fletch environment variables.
# copy to .env and fill in. never commit .env. secrets live here and only here.
# non-secret tunables have defaults in packages/config/config.ts; env vars
# listed here override them per deployment.

# ---------------------------------------------------------------------------
# chain (verified defaults live in config.ts; override per deployment)
# ---------------------------------------------------------------------------

# robinhood chain id. defaults to 4663. leave blank to use the default.
FLETCH_CHAIN_ID=

# robinhood chain https json-rpc endpoint. defaults to the public endpoint
# https://rpc.mainnet.chain.robinhood.com, which is rate limited. for
# production and for pool discovery, set this to an alchemy or quicknode
# robinhood chain url. do not run the indexer against the public endpoint.
FLETCH_RPC_URL=

# block explorer base url. defaults to https://robinhoodchain.blockscout.com.
FLETCH_EXPLORER_URL=

# blockscout verifier base for forge contract verification. defaults to
# https://robinhoodchain.blockscout.com/api/.
FLETCH_VERIFIER_URL=

# deployed FletchCommits contract address. known after the contract deploy
# step in SETUP.md.
FLETCH_COMMITS_ADDRESS=

# ---------------------------------------------------------------------------
# database (required)
# ---------------------------------------------------------------------------

# supabase postgres connection string. use the pooled connection string from
# the supabase dashboard (transaction mode) for the api, and the direct
# string for the indexer if you prefer. this is a secret.
DATABASE_URL=

# ---------------------------------------------------------------------------
# publisher (required for onchain commits)
# ---------------------------------------------------------------------------

# hex private key (0x...) of the publisher wallet. must match the publisher
# address set on the FletchCommits contract. fund with a little eth on
# robinhood chain for gas. this is a secret. never log it.
PUBLISHER_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# contract deploy (used only by foundry, see packages/contracts)
# ---------------------------------------------------------------------------

# deployer private key for forge script. can be the same wallet as the
# publisher for v1. this is a secret.
DEPLOYER_PRIVATE_KEY=

# public address of the publisher wallet, passed to the constructor at
# deploy time. derives from PUBLISHER_PRIVATE_KEY.
PUBLISHER_ADDRESS=

# ---------------------------------------------------------------------------
# api
# ---------------------------------------------------------------------------

API_PORT=8080
API_HOST=0.0.0.0

# single origin or * for the dashboard during development.
API_CORS_ORIGIN=*

# bearer token protecting the admin endpoints (anchor inserts, key creation).
# generate something long and random. this is a secret.
ADMIN_TOKEN=

# enable the x402 payment-required path on price endpoints. settlement
# verification is a stub interface until wired (see apps/api/src/x402.ts).
X402_ENABLED=false

# ---------------------------------------------------------------------------
# indexer
# ---------------------------------------------------------------------------

# poll interval in ms (default 30000) and cycle length in seconds (default
# 600). defaults live in config.ts; override here per environment.
FLETCH_POLL_MS=
FLETCH_CYCLE_SECONDS=
FLETCH_TWAP_WINDOW_SECONDS=

# run the whole pipeline against synthetic pools and proxies. lets you boot
# indexer, api, and web before any placeholder is filled.
MOCK_MODE=false

# eth/usd source for dollarizing weth-quoted pools. only fetched when a
# tracked token uses a weth pool (none in the default launch set). set the
# endpoint and json path when enabling a weth token; staleness in ms gates
# whether a weth token is skipped (degrades confidence) vs dollarized.
FLETCH_ETHUSD_URL=
FLETCH_ETHUSD_JSONPATH=
FLETCH_ETHUSD_STALENESS_MS=

# anchor automation. off by default; the manual admin endpoints work either
# way. when true, the indexer inserts close and open anchors on schedule from
# the sources in config (anchors.sources, wire their urls and json path).
# delays are minutes after the official close/open; missed-hours is the ops
# alert deadline.
FLETCH_ANCHOR_AUTOMATED=false
FLETCH_ANCHOR_CLOSE_DELAY_MIN=
FLETCH_ANCHOR_OPEN_DELAY_MIN=
FLETCH_ANCHOR_MISSED_HOURS=
FLETCH_ANCHOR_STALE_GRACE_MIN=

# ops alert cooldown in ms: how often the same condition may re-notify.
FLETCH_OPS_COOLDOWN_MS=

# ---------------------------------------------------------------------------
# web (vercel)
# ---------------------------------------------------------------------------

# public base url of the fletch api, e.g. https://api.fletch.example
NEXT_PUBLIC_API_URL=

# public explorer base url for tx links. defaults to the blockscout url.
NEXT_PUBLIC_EXPLORER_URL=
