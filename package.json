{
  "name": "morrow",
  "private": true,
  "version": "0.1.0",
  "description": "off-hours fair value oracle for tokenized equities on robinhood chain",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck && tsc -p scripts/tsconfig.json --noEmit",
    "discover-pools": "tsx scripts/discover-pools.ts",
    "receipts": "pnpm --filter @morrow/receipts start",
    "dev:indexer": "pnpm --filter @morrow/indexer dev",
    "dev:api": "pnpm --filter @morrow/api dev",
    "dev:web": "pnpm --filter @morrow/web dev"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@morrow/config": "workspace:*",
    "@morrow/discovery": "workspace:*",
    "@morrow/engine": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "viem": "^2.21.0"
  }
}
