{
  "name": "@morrow/mcp-server",
  "version": "0.1.0",
  "description": "mcp server for morrow, the off-hours fair value oracle for tokenized equities on robinhood chain. read-only data tools plus independent merkle verification against the on-chain commit registry.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "morrow-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keycho/morrow.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/keycho/morrow/tree/main/packages/mcp#readme",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "echo verification logic is exercised by the engine test suite and the api smoke test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "oracle",
    "robinhood-chain",
    "fair-value",
    "tokenized-equities"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "viem": "^2.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
